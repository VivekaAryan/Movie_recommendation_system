# Backend configuration (copy to .env and adjust as needed)
# NEVER commit .env — it is gitignored

# Ollama — run `ollama list` to see installed models
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:1b-instruct-q4_K_M

# Optional: disable summaries entirely
SKIP_SUMMARY=false

# Paths (relative to project root)
FAISS_INDEX_PATH=data/faiss_index
METADATA_CSV=Data/final_metadata.csv

# Server (used by Makefile / docs)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Next.js BFF proxy target (server-side only, not exposed to browser)
BACKEND_URL=http://127.0.0.1:8000
